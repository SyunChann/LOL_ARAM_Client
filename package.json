{
  "name": "aram-mayhem-records",
  "description": "롤 클라이언트 기반 아수라장 전적 데스크톱 앱",
  "author": "ARAM Mayhem Records",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "desktop": "npm run build && electron .",
    "package:win": "npm run build && electron-builder --win nsis portable"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.aram-mayhem.records",
    "productName": "아수라장 전적",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "web-dist/**",
      "electron-main.js",
      "vite.config.js"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
